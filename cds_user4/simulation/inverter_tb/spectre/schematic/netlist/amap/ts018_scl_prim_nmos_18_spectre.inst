HEADER
"PSFversion" "1.00"
"Dv" ":dv"
"Gv" ":gv"
"Sv" ":sv"
"Bv" ":bv"
"(op ?)p" "id is vdsat isub"
"(op id)p" "tspGetOp('cmos mappedInst() 'id)"
"(op is)p" "tspGetOp('cmos mappedInst() 'is)"
"(op vdsat)p" "tspGetOp('cmos mappedInst() 'vdsat)"
"(op isub)p" "tspGetOp('cmos mappedInst() 'isub)"
"(opt ?)p" "id is vdsat isub"
"(opt id)p" "tspGetOpt('cmos mappedInst() 'id)"
"(opt is)p" "tspGetOpt('cmos mappedInst() 'is)"
"(opt vdsat)p" "tspGetOpt('cmos mappedInst() 'vdsat)"
"(opt isub)p" "tspGetOpt('cmos mappedInst() 'isub)"
